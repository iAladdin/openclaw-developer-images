{
  "name": "openclaw-images",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "catalog": "node scripts/list-profiles.mjs",
    "recommend": "node scripts/recommend-image.mjs",
    "build-matrix": "node scripts/print-build-matrix.mjs",
    "build:profile": "node scripts/build-profile.mjs",
    "create:instance": "node scripts/create-instance.mjs",
    "ocdev": "node packages/cli/bin/ocdev",
    "verify:cli-pack": "node scripts/verify-cli-pack.mjs",
    "test": "node --test test/*.test.mjs"
  }
}
