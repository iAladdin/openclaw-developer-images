{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "memorySearch": {
        "enabled": false
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["http://127.0.0.1:18789", "http://localhost:18789"]
    },
    "auth": {
      "mode": "token",
      "token": "__REPLACE_WITH_GATEWAY_TOKEN__"
    }
  }
}
