// Docker-first local developer profile template.
// Copy this file to /home/node/.openclaw/openclaw.json before first start,
// or merge the fields into an existing state directory.
//
// Notes:
// - This template assumes `-p 18789:18789`.
// - If you change the host port, update `gateway.controlUi.allowedOrigins`.
// - First browser login still requires one-time device pairing approval.

{
  agents: {
    defaults: {
      compaction: {
        mode: "safeguard",
      },
      memorySearch: {
        enabled: false,
      },
      maxConcurrent: 4,
      subagents: {
        maxConcurrent: 8,
      },
    },
  },
  messages: {
    ackReactionScope: "group-mentions",
  },
  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw",
  },
  gateway: {
    mode: "local",
    port: 18789,
    bind: "lan",
    controlUi: {
      allowedOrigins: [
        "http://127.0.0.1:18789",
        "http://localhost:18789",
      ],
    },
    auth: {
      mode: "token",
      token: "__REPLACE_WITH_GATEWAY_TOKEN__",
    },
  },
}
